  "tests": [
    {
      "id": 1,
      "test": "hpp_dup_simple",
      "version": "v5",
      "data": {
        "query": "role=user&role=admin",
        "parsed": "{'role': ['user', 'admin']}",
        "role_type": "list",
        "role_value": "['user', 'admin']"
      }
    },
    {
      "id": 2,
      "test": "hpp_dup_triple",
      "version": "v5",
      "data": {
        "query": "role=user&role=admin&role=superadmin",
        "parsed": "{'role': ['user', 'admin', 'superadmin']}",
        "role_type": "list",
        "role_value": "['user', 'admin', 'superadmin']"
      }
    },
    {
      "id": 3,
      "test": "hpp_array_notation",
      "version": "v5",
      "data": {
        "query": "role[]=user&role[]=admin",
        "parsed": "{'role[]': ['user', 'admin']}",
        "role_type": "undefined",
        "role_value": null
      }
    },
    {
      "id": 4,
      "test": "hpp_mixed_dup_array",
      "version": "v5",
      "data": {
        "query": "role=user&role[]=admin",
        "parsed": "{'role': 'user', 'role[]': 'admin'}",
        "role_type": "str",
        "role_value": "user"
      }
    },
    {
      "id": 5,
      "test": "hpp_dup_with_index",
      "version": "v5",
      "data": {
        "query": "role[0]=user&role[1]=admin",
        "parsed": "{'role[0]': 'user', 'role[1]': 'admin'}",
        "role_type": "undefined",
        "role_value": null
      }
    },
    {
